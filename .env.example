# ─── LLM ───────────────────────────────────────────────────────────
LLM_BASE_URL=
LLM_MODEL=gpt-oss-120b

# ─── OAuth2 client-credentials (for LLM token) ────────────────────
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ─── Run behaviour ─────────────────────────────────────────────────
# autonomous | human (default: human)
RUN_MODE=human
# Max bug-fix iterations before stopping the loop (default: 3)
MAX_BUGFIX_ITERATIONS=3
# Max parallel developer agents (default: 3)
MAX_CONCURRENT_DEVS=3

# ─── Paths ─────────────────────────────────────────────────────────
# Base directory for generated products (default: ./generated-projects)
GENERATED_PROJECTS_DIR=./generated-projects
# Run logs and state snapshots (default: ./outputs)
OUTPUTS_DIR=./outputs

# ─── Docker ────────────────────────────────────────────────────────
# Optional: Docker Engine endpoint (default: local socket)
DOCKER_HOST=

# ─── Playwright MCP ────────────────────────────────────────────────
# Override the command/args to launch the Playwright MCP server
PLAYWRIGHT_MCP_CMD=npx
PLAYWRIGHT_MCP_ARGS=@playwright/mcp@latest --headless

# ─── GitHub ────────────────────────────────────────────────────────
# GitHub PAT or app token for PR operations (requires 'repo' scope)
GITHUB_TOKEN=
# Repository owner (org or user)
GITHUB_OWNER=
# Repository name
GITHUB_REPO=
# Default branch name (default: main)
GIT_DEFAULT_BRANCH=main
# Max PR review rounds before escalation (default: 5)
MAX_REVIEW_ITERATIONS=5

# ─── Dashboard ─────────────────────────────────────────────────────
DASHBOARD_PORT=3000
