{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"]
  },
  "include": ["src", "src/**/*.tsx", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.test.tsx", "src/**/*.test.ts"]
}
